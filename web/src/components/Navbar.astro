---
import { localeLinks } from '../lib/siteContent';
import { Image } from 'astro:assets';
import logoLight from '../assets/Logo_vidra_sinfondo_letrablanca.png';
import logoDark from '../assets/Logo_vidra_sinfondo_letranegra.png';

const { locale = 'es' } = Astro.props;
const links = localeLinks[locale as keyof typeof localeLinks]?.nav ?? localeLinks.es.nav;
const switchLabel = localeLinks[locale as keyof typeof localeLinks]?.switchLabel ?? 'EN';
const homeHref = locale === 'en' ? '/en' : '/';
const pathname = Astro.url.pathname;
const switchHref =
  locale === 'en'
    ? pathname.replace(/^\/en/, '') || '/'
    : `/en${pathname === '/' ? '' : pathname}`;
const languageLabel = locale === 'en' ? 'Language' : 'Idioma';
---

<header class="fixed left-0 right-0 top-0 z-50 px-4 py-4 md:px-6">
  <div
    id="menu-overlay"
    class="pointer-events-none fixed inset-0 z-0 bg-[#0B2C4A]/0 backdrop-blur-0 transition-all duration-500 ease-out"
  ></div>

  <nav
    id="site-nav"
    class="relative z-10 mx-auto flex h-[4.5rem] max-w-7xl items-center justify-between rounded-[1.25rem] border border-white/10 bg-[#0B2C4A] px-5 text-white shadow-[0_12px_40px_rgba(7,23,41,0.18)] backdrop-blur-md transition-colors duration-300 md:px-6"
  >
    <a href={homeHref} class="flex items-center gap-3 border-r border-white/10 pr-5 md:pr-6" aria-label="Vidra home">
        <Image
            id="site-logo"
            src={logoLight}
            data-logo-light={logoLight.src}
            data-logo-dark={logoDark.src}
            width={180}
            height={60}
            class="h-[60px] max-h-[60px] w-[180px] object-contain"
            alt="Vidra"
            loading="eager"
            decoding="async"
        />
    </a>

    <div id="site-links" class="hidden items-center gap-9 text-[0.78rem] font-medium uppercase tracking-[0.18em] text-white/68 md:flex">
      {links.map((item: any) => (
        <a class="transition hover:text-white" href={item.href}>{item.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
        <a
            href={switchHref}
            aria-label={languageLabel}
            class="nav-icon grid h-10 min-w-10 place-items-center rounded-full border border-white/10 bg-white/8 px-3 text-xs font-semibold uppercase tracking-[0.14em] text-white transition hover:bg-white/14"
        >
            {switchLabel}
        </a>
      <button id="search-btn" aria-label="Buscar" class="nav-icon hidden h-10 w-10 place-items-center rounded-full border border-white/10 bg-white/8 text-white transition hover:bg-white/14 md:grid">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15z" />
        </svg>
      </button>

      <div
        id="search-panel"
        class="pointer-events-none absolute right-20 top-[5.25rem] z-30 w-[min(28rem,calc(100vw-2rem))] translate-y-3 scale-95 rounded-2xl border border-white/10 bg-[#0B2C4A] p-3 text-white opacity-0 shadow-[0_24px_70px_rgba(7,23,41,0.32)] transition-all duration-300"
      >
        <input
            id="search-input"
            type="search"
            placeholder={locale === "en" ? "Search..." : "Buscar..."}
            class="w-full rounded-xl border border-white/10 bg-white/10 px-4 py-3 text-sm text-white outline-none placeholder:text-white/45"
        />

        <div id="search-results" class="mt-3 grid gap-1"></div>
      </div>

      <div class="relative">
        <button id="menu-btn" aria-label="Abrir menú" class="nav-icon grid h-10 w-10 place-items-center rounded-full border border-white/10 bg-white/8 text-white transition hover:bg-white/14 md:hidden">          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <rect x="3" y="7" width="18" height="2" rx="1" />
            <rect x="3" y="15" width="18" height="2" rx="1" />
          </svg>
        </button>

        <div
            id="menu-dropdown"
            class="pointer-events-none absolute right-0 z-20 mt-3 w-56 origin-top-right translate-y-3 scale-95 rounded-2xl border border-white/10 bg-[#0B2C4A] p-2 text-white opacity-0 shadow-[0_24px_70px_rgba(7,23,41,0.32)] transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] md:hidden"
        >
          {links.map((item: any) => (
            <a href={item.href} class="block rounded-xl px-4 py-3 text-sm text-white/75 transition hover:bg-white/10 hover:text-white">{item.label}</a>
          ))}
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  (() => {
    const nav = document.getElementById('site-nav');
    const logo = document.getElementById('site-logo');
    const links = document.getElementById('site-links');
    const mobileContact = document.getElementById('mobile-contact');
    const icons = document.querySelectorAll('.nav-icon');
    const dropdown = document.getElementById('menu-dropdown');
    const dropdownLinks = dropdown?.querySelectorAll('a');

    if (!(nav instanceof HTMLElement)) return;
    if (!(logo instanceof HTMLImageElement)) return;
    if (!(links instanceof HTMLElement)) return;

    const lightLogo = logo.dataset.logoLight || '/Logo_vidra_sinfondo_letrablanca.png';
    const darkLogo = logo.dataset.logoDark || '/Logo_vidra_sinfondo_letranegra.png';

    const setLightNav = () => {
        nav.classList.remove('bg-[#0B2C4A]', 'border-white/10', 'text-white');
        nav.classList.add('bg-white', 'border-[#0B2C4A]/10', 'text-[#0B2C4A]');

        logo.setAttribute('src', darkLogo);

        links.classList.remove('text-white/68', 'text-[#0B2C4A]/70');
        links.classList.add('text-black/68');

        links.querySelectorAll('a').forEach((link) => {
            link.classList.remove('hover:text-white');
            link.classList.add('hover:text-black');
        });

        mobileContact?.classList.remove('border-white/15', 'text-white');
        mobileContact?.classList.add('border-[#0B2C4A]/15', 'text-[#0B2C4A]');

        icons.forEach((icon) => {
            icon.classList.remove('border-white/10', 'bg-white/8', 'text-white', 'hover:bg-white/14');
            icon.classList.add('border-[#0B2C4A]/10', 'bg-[#0B2C4A]/5', 'text-[#0B2C4A]', 'hover:bg-[#0B2C4A]/10');
        });

        dropdown?.classList.remove('bg-[#0B2C4A]', 'border-white/10', 'text-white');
        dropdown?.classList.add('bg-white', 'border-[#0B2C4A]/10', 'text-[#0B2C4A]');

        dropdownLinks?.forEach((link) => {
            link.classList.remove('text-white/75', 'hover:bg-white/10', 'hover:text-white');
            link.classList.add('text-[#0B2C4A]/75', 'hover:bg-[#0B2C4A]/10', 'hover:text-[#0B2C4A]');
        });
        };

        const setDarkNav = () => {
        nav.classList.remove('bg-white', 'border-[#0B2C4A]/10', 'text-[#0B2C4A]');
        nav.classList.add('bg-[#0B2C4A]', 'border-white/10', 'text-white');

        logo.setAttribute('src', lightLogo);

        links.classList.remove('text-black/68', 'text-[#0B2C4A]/70');
        links.classList.add('text-white/68');

        links.querySelectorAll('a').forEach((link) => {
            link.classList.remove('hover:text-black');
            link.classList.add('hover:text-white');
        });

        mobileContact?.classList.remove('border-[#0B2C4A]/15', 'text-[#0B2C4A]');
        mobileContact?.classList.add('border-white/15', 'text-white');

        icons.forEach((icon) => {
            icon.classList.remove('border-[#0B2C4A]/10', 'bg-[#0B2C4A]/5', 'text-[#0B2C4A]', 'hover:bg-[#0B2C4A]/10');
            icon.classList.add('border-white/10', 'bg-white/8', 'text-white', 'hover:bg-white/14');
        });

        dropdown?.classList.remove('bg-white', 'border-[#0B2C4A]/10', 'text-[#0B2C4A]');
        dropdown?.classList.add('bg-[#0B2C4A]', 'border-white/10', 'text-white');

        dropdownLinks?.forEach((link) => {
            link.classList.remove('text-[#0B2C4A]/75', 'hover:bg-[#0B2C4A]/10', 'hover:text-[#0B2C4A]');
            link.classList.add('text-white/75', 'hover:bg-white/10', 'hover:text-white');
        });
        };

    const sections = document.querySelectorAll('[data-nav-theme="light"]');

    const checkNavTheme = () => {
      const navMiddle = 88;
      let isOverDarkSection = false;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();

        if (rect.top <= navMiddle && rect.bottom >= navMiddle) {
          isOverDarkSection = true;
        }
      });

      if (isOverDarkSection) setLightNav();
      else setDarkNav();
    };

    checkNavTheme();
    window.addEventListener('scroll', checkNavTheme, { passive: true });
    window.addEventListener('resize', checkNavTheme);
  })();

  (() => {
    const btn = document.getElementById('menu-btn');
    const dropdown = document.getElementById('menu-dropdown');
    const overlay = document.getElementById('menu-overlay');

    if (!btn || !dropdown || !overlay) return;

    const openMenu = () => {
      dropdown.classList.remove('pointer-events-none', 'opacity-0', 'translate-y-3', 'scale-95');
      dropdown.classList.add('opacity-100', 'translate-y-0', 'scale-100');

      overlay.classList.remove('pointer-events-none', 'bg-[#0B2C4A]/0', 'backdrop-blur-0');
      overlay.classList.add('bg-[#0B2C4A]/70', 'backdrop-blur-sm');
    };

    const closeMenu = () => {
      dropdown.classList.add('pointer-events-none', 'opacity-0', 'translate-y-3', 'scale-95');
      dropdown.classList.remove('opacity-100', 'translate-y-0', 'scale-100');

      overlay.classList.add('pointer-events-none', 'bg-[#0B2C4A]/0', 'backdrop-blur-0');
      overlay.classList.remove('bg-[#0B2C4A]/70', 'backdrop-blur-sm');
    };

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.classList.contains('opacity-0') ? openMenu() : closeMenu();
    });

    dropdown.addEventListener('click', (e) => e.stopPropagation());
    overlay.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  })();

  (() => {
  const searchBtn = document.getElementById("search-btn");
  const searchPanel = document.getElementById("search-panel");
  const searchInput = document.getElementById("search-input");
  const searchResults = document.getElementById("search-results");
  const overlay = document.getElementById("menu-overlay");

  if (
    !searchBtn ||
    !searchPanel ||
    !searchResults ||
    !overlay ||
    !(searchInput instanceof HTMLInputElement)
  ) return;

  const pages: { title: string; href: string; keywords: string[] }[] = [
    {
      title: "Inicio",
      href: "/",
      keywords: ["home", "inicio", "vidra"],
    },
    {
      title: "Servicios",
      href: "/services",
      keywords: ["servicios", "services", "ia", "automatización", "datos"],
    },
    {
      title: "Quiénes somos",
      href: "/who-we-are",
      keywords: ["quienes somos", "equipo", "empresa", "vidra"],
    },
    {
      title: "Contacto",
      href: "/contact",
      keywords: ["contacto", "email", "teléfono", "ubicación"],
    },
    {
      title: "Analytics",
      href: "/services/analytics",
      keywords: ["analytics", "analítica", "datos", "auditoría"],
    },
    {
      title: "Machine Learning",
      href: "/services/machine-learning",
      keywords: ["machine learning", "modelos predictivos", "predicción"],
    },
    {
      title: "Deep Learning",
      href: "/services/deep-learning",
      keywords: ["deep learning", "redes neuronales", "ia avanzada"],
    },
  ];

  const getMatches = (query: string) => {
    const normalizedQuery = query.trim().toLowerCase();

    if (!normalizedQuery) return pages;

    return pages.filter((page) => {
      const searchableText = [
        page.title,
        page.href,
        ...page.keywords,
      ]
        .join(" ")
        .toLowerCase();

      return searchableText.includes(normalizedQuery);
    });
  };

  const goToSearch = (query: string) => {
    const matches = getMatches(query);

    if (matches.length > 0) {
      window.location.href = matches[0].href;
      return;
    }

    const searchPath = window.location.pathname.startsWith("/en")
      ? "/en/search"
      : "/search";

    window.location.href = `${searchPath}?q=${encodeURIComponent(query)}`;
  };

  const renderResults = (query: string) => {
    const matches = getMatches(query);

    searchResults.innerHTML = matches
      .map(
        (page) => `
          <a
            href="${page.href}"
            class="block rounded-xl px-4 py-3 text-sm text-white/75 transition hover:bg-white/10 hover:text-white"
          >
            ${page.title}
          </a>
        `
      )
      .join("");
  };

  const openSearch = () => {
    searchPanel.classList.remove("pointer-events-none", "opacity-0", "translate-y-3", "scale-95");
    searchPanel.classList.add("opacity-100", "translate-y-0", "scale-100");

    overlay.classList.remove("pointer-events-none", "bg-[#0B2C4A]/0", "backdrop-blur-0");
    overlay.classList.add("bg-[#0B2C4A]/70", "backdrop-blur-sm");

    searchInput.focus();
    renderResults("");
  };

  const closeSearch = () => {
    searchPanel.classList.add("pointer-events-none", "opacity-0", "translate-y-3", "scale-95");
    searchPanel.classList.remove("opacity-100", "translate-y-0", "scale-100");

    overlay.classList.add("pointer-events-none", "bg-[#0B2C4A]/0", "backdrop-blur-0");
    overlay.classList.remove("bg-[#0B2C4A]/70", "backdrop-blur-sm");

    searchInput.value = "";
  };

  searchBtn.addEventListener("click", (event) => {
    event.stopPropagation();

    searchPanel.classList.contains("opacity-0")
      ? openSearch()
      : closeSearch();
  });

  searchInput.addEventListener("input", () => {
    renderResults(searchInput.value);
  });

  searchInput.addEventListener("keydown", (event) => {
    if (event.key !== "Enter") return;

    event.preventDefault();
    goToSearch(searchInput.value);
  });

  searchPanel.addEventListener("click", (event) => event.stopPropagation());
  overlay.addEventListener("click", closeSearch);

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeSearch();
  });
})();
</script>
