---
import { processContent, type Locale } from "../lib/siteContent";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = processContent[locale];
const steps = content.steps;
---

<section id="process" class="bg-white px-4 py-16 md:px-6 md:py-20">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 md:grid-cols-[0.8fr_4rem_1.2fr]">
      <div class="md:sticky md:top-32 md:self-start">
        <p class="mb-4 text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-[#0d3c78]">
          {content.eyebrow}
        </p>

        <h2 class="max-w-xl text-[clamp(1.6rem,2.8vw,2.8rem)] font-medium leading-[1] tracking-[-0.04em] text-[#071729]">
          {content.title}
        </h2>
      </div>

      <div class="hidden md:flex md:justify-center">
        <div class="sticky top-32 h-[200px] self-start">
          <div class="relative h-full w-[3px] rounded-full bg-[#071729]/12">
            <div
              id="process-progress"
              class="absolute left-0 top-0 w-full rounded-full bg-[#00B2EB]"
              style="height: 0%;"
            ></div>
          </div>
        </div>
      </div>

      <div class="process-stack relative pb-12 md:pb-16" style={`min-height: ${steps.length * 52}vh;`}>
        {steps.map((step, index) => (
          <article
            class="process-card sticky overflow-hidden rounded-[1.1rem] border border-[#071729]/10 bg-white shadow-[0_10px_28px_rgba(7,23,41,0.06)] transition-[transform,opacity,box-shadow] duration-500 ease-out"
            style={`top: ${8 + index * 0.75}rem; margin-top: ${index === 0 ? "0" : "-1.65rem"};`}
            data-index={index}
          >
            <div class="process-card-inner p-5 transition-[padding,transform] duration-500 ease-out md:p-6">
              <div class="flex items-center justify-between gap-6">
                <span class="text-[0.78rem] font-semibold tracking-[0.08em] text-[#00B2EB]">
                  {step.number}
                </span>

                <span class="h-2 w-2 rounded-full bg-[#00B2EB]"></span>
              </div>

              <h3 class="mt-3 text-[clamp(1.35rem,2.3vw,2.1rem)] font-medium leading-[0.98] tracking-[-0.04em] text-[#071729]">
                {step.title}
              </h3>

              <p class="process-outcome mt-2 text-[0.76rem] font-medium uppercase tracking-[0.14em] text-[#0d3c78]/70">
                {step.outcome}
              </p>

              <p class="process-description mt-3 max-w-xl text-[0.9rem] leading-6 text-[#071729]/66">
                {step.description}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // @ts-nocheck
  (() => {
    const section = document.getElementById("process");
    const progress = document.getElementById("process-progress");
    const cards = Array.from(document.querySelectorAll(".process-card"));

    if (!section || !progress || !cards.length) return;

    const updateProcess = () => {
      const rect = section.getBoundingClientRect();
      const sectionHeight = section.offsetHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), sectionHeight);
      const percent = sectionHeight > 0 ? (scrolled / sectionHeight) * 100 : 0;

      progress.style.height = `${percent}%`;

      const activeIndex = Math.min(
        cards.length - 1,
        Math.max(0, Math.floor((percent / 100) * cards.length))
      );

      cards.forEach((card, index) => {
        const isActive = index === activeIndex;
        const isLastPrevious = index === activeIndex - 1;
        const isUpcoming = index > activeIndex;

        const offset = isUpcoming ? (index - activeIndex) * 6 : 0;
        const scale = isActive ? 1 : isLastPrevious ? 0.97 : 0.985;
        const opacity = isActive ? 1 : isLastPrevious ? 0.64 : isUpcoming ? 0.26 : 0;

        card.style.transform = isLastPrevious
          ? `translateY(-36px) scale(${scale})`
          : `translateY(${offset}px) scale(${scale})`;

        card.style.opacity = opacity;
        card.style.zIndex = isActive ? "30" : isLastPrevious ? "20" : isUpcoming ? "10" : "0";
        card.style.pointerEvents = isActive ? "auto" : "none";

        const inner = card.querySelector(".process-card-inner");
        const description = card.querySelector(".process-description");
        const outcome = card.querySelector(".process-outcome");

        if (inner) {
          inner.style.padding = isActive ? "1.4rem 1.5rem" : "0.95rem 1.15rem";
        }

        if (outcome) {
          outcome.style.opacity = isActive ? "1" : "0.7";
        }

        if (description) {
          description.style.maxHeight = isActive ? "5rem" : "0";
          description.style.opacity = isActive ? "1" : "0";
          description.style.overflow = "hidden";
          description.style.transition = "max-height 450ms ease, opacity 350ms ease";
        }
      });
    };

    updateProcess();

    window.addEventListener("scroll", updateProcess, { passive: true });
    window.addEventListener("resize", updateProcess);
  })();
</script>
