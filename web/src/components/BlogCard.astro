---
import { Image } from 'astro:assets';
import { blogPageContent, type Locale } from '../lib/siteContent';

const { post, locale } = Astro.props as {
  post: any;
  locale: Locale;
};

const { title, description, pubDate, category, image } = post.data;

const t = blogPageContent[locale];
const baseHref = locale === 'en' ? '/en/blog/' : '/blog/';
const slug = post.id.replace(/\.md$/, '');
const postUrl = `${baseHref}${slug}/`;

const dateLocale = locale === 'en' ? 'en-US' : 'es-ES';
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-black/5 bg-white transition-all hover:shadow-xl hover:shadow-blue/5">
  <a href={postUrl} class="block aspect-video overflow-hidden">
    <Image
      src={image || "/images/blog-placeholder.jpg"}
      alt={title}
      loading="eager"
      width={800}
      height={450}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </a>

  <div class="flex flex-1 flex-col p-6">
    <div class="mb-3 flex items-center gap-3">
      <span class="rounded-full bg-blue/5 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-blue">
        {t.categories[category as keyof typeof t.categories]}
      </span>

      <time class="text-[11px] font-medium uppercase tracking-tight text-black/40">
        {new Intl.DateTimeFormat(dateLocale, { dateStyle: 'medium' }).format(pubDate)}
      </time>
    </div>

    <h3 class="mb-3 text-xl font-bold leading-snug text-ink group-hover:text-blue">
      <a href={postUrl}>{title}</a>
    </h3>

    <p class="mb-6 line-clamp-3 text-sm leading-relaxed text-black/60">
      {description}
    </p>

    <div class="mt-auto border-t border-black/5 pt-4">
      <a href={postUrl} class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-ink transition-colors hover:text-blue">
        {t.readMore} <span class="text-lg">→</span>
      </a>
    </div>
  </div>
</article>