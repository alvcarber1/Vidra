---
import { Image } from "astro:assets";
import analysisImage from "../../assets/analysis-hero.png";
import machineLearningImage from "../../assets/machine-learning-hero.png";
import deepLearningImage from "../../assets/deep-learning-hero.png";
import BaseLayout from "../../layouts/Layout.astro";
import { serviceContent, type Locale } from "../../lib/siteContent";

const locale: Locale = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const content = serviceContent[locale];
const heroImages = {
  "analysis-hero": analysisImage,
  "machineLearning-hero": machineLearningImage,
  "deepLearning-hero": deepLearningImage,
} as const;

type HeroImageKey = keyof typeof heroImages;

export function getStaticPaths() {
  const slugs = ["analysis", "machine-learning", "deep-learning"];
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const service = content.detail[slug as keyof typeof content.detail];
const shared = content.detailShared;

if (!service) {
  return Astro.redirect(locale === "es" ? "/services" : "/en/services");
}

const contactHref = locale === "es" ? "/#contact" : "/en/#contact";
const servicesHref = locale === "es" ? "/services" : "/en/services";
---

<BaseLayout title={`${service.title} | Vidra`} description={service.description}>
  <main class="bg-[#eef4fb] pt-24">
    <section class="px-4 py-12 md:px-6 md:py-16">
      <div class="mx-auto max-w-7xl">
        <a href={servicesHref} class="mb-10 inline-flex text-sm font-medium text-[#0B2C4A]/70 hover:text-[#0B2C4A]">
          {shared.backLabel}
        </a>

        <div class="grid gap-10 border-t border-[#0B2C4A]/15 pt-10 lg:grid-cols-[1fr_0.92fr] lg:items-start">
          <div>
            <p class="mb-6 text-[0.78rem] font-semibold uppercase tracking-[0.22em] text-[#00B2EB]">
              {service.eyebrow}
            </p>

            <h1 class="max-w-3xl text-[clamp(2.1rem,5vw,3.8rem)] font-medium leading-[1] tracking-[-0.04em] text-[#0B2C4A]">
              {service.title}
            </h1>

            <p class="mt-6 max-w-2xl text-[1.08rem] leading-8 text-[#0B2C4A]/72 md:text-[1.15rem]">
              {service.description}
            </p>

            <div class="mt-10 grid gap-4 sm:grid-cols-3">
              {shared.scopeCards.map((card) => (
                <div class="rounded-[1.1rem] border border-[#0B2C4A]/10 bg-white p-5 shadow-[0_12px_30px_rgba(11,44,74,0.05)]">
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#0B2C4A]/45">
                    {card.title}
                  </p>
                  <p class="mt-3 text-sm leading-6 text-[#0B2C4A]/78">
                    {card.text}
                  </p>
                </div>
              ))}
            </div>
          </div>

          <div class="lg:pt-2">
            <div class="overflow-hidden rounded-[2rem] bg-[#0B2C4A] p-4 shadow-[0_28px_80px_rgba(11,44,74,0.18)]">
              <Image
                src={heroImages[service.heroImageKey as HeroImageKey]}
                alt={`Imagen principal del servicio ${service.title}`}
                class="aspect-[4/5] w-full rounded-[1.4rem] object-cover"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
        </div>

        <div class="mt-16 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div class="rounded-[1.8rem] border border-[#0B2C4A]/10 bg-white p-6 shadow-[0_18px_50px_rgba(11,44,74,0.06)] md:p-8">
            <p class="text-[0.78rem] font-semibold uppercase tracking-[0.22em] text-[#00B2EB]">
              {shared.coversEyebrow}
            </p>

            <h2 class="mt-4 text-[clamp(1.6rem,2.8vw,2.6rem)] font-medium leading-[0.98] tracking-[-0.045em] text-[#0B2C4A]">
              {shared.coversTitle}
            </h2>

            <p class="mt-5 max-w-xl text-[1rem] leading-7 text-[#0B2C4A]/68">
              {shared.coversText}
            </p>

            <div class="mt-8 divide-y divide-[#0B2C4A]/10 border-y border-[#0B2C4A]/10">
              {service.points.map((point, index) => (
                <article class="grid gap-4 py-5 md:grid-cols-[4rem_1fr] md:items-start">
                  <span class="font-semibold text-[#00B2EB]">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <p class="text-[1.05rem] font-medium text-[#0B2C4A]">
                    {point}
                  </p>
                </article>
              ))}
            </div>

            <a
              href={contactHref}
              class="mt-10 inline-flex rounded-full bg-[#0B2C4A] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#00B2EB] hover:text-[#0B2C4A]"
            >
              {shared.ctaLabel}
            </a>
          </div>

          <div class="rounded-[1.8rem] border border-[#0B2C4A]/10 bg-[#0B2C4A] p-6 text-white shadow-[0_18px_50px_rgba(11,44,74,0.12)] md:p-8">
            <p class="text-[0.78rem] font-semibold uppercase tracking-[0.22em] text-white/55">
              {shared.deliveryEyebrow}
            </p>

            <h2 class="mt-4 text-[clamp(1.6rem,2.8vw,2.4rem)] font-medium leading-[0.98] tracking-[-0.045em]">
              {shared.deliveryTitle}
            </h2>

            <div class="mt-8 space-y-4 text-[0.98rem] leading-7 text-white/72">
              {shared.deliveryParagraphs.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>