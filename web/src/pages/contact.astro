---
import { contactPageContent, type Locale } from "../lib/siteContent";
import BaseLayout from "../layouts/Layout.astro";

const locale: Locale = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const content = contactPageContent[locale];

const office = content.office;
const telHref = `tel:${office.phone.replace(/\s/g, "")}`;
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(office.address)}&output=embed`;
---

<BaseLayout title={content.title} description={content.description}>
  <main class="bg-[#eef4fb] pt-24">
    <section class="px-4 pb-16 pt-14 md:px-6 md:pb-24 md:pt-20">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-10 border-t border-[#0B2C4A]/12 pt-10 lg:items-end">
          <div>
            <p class="mb-6 text-[0.78rem] font-semibold uppercase tracking-[0.24em] text-[#00B2EB]">
              {content.hero.eyebrow}
            </p>

            <h1 class="max-w-4xl text-[clamp(2.2rem,4.8vw,4.4rem)] font-medium leading-[0.98] tracking-[-0.05em] text-[#0B2C4A]">
              {content.hero.title}
            </h1>

            <p class="mt-6 max-w-4xl text-[1.05rem] leading-8 text-[#0B2C4A]/68">
              {content.hero.text}
            </p>
          </div>
      </div>
    </section>

    <section class="px-4 pb-20 md:px-6 md:pb-28">
      <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="rounded-[2rem] bg-[#0B2C4A] p-8 text-white shadow-[0_28px_90px_rgba(11,44,74,0.20)] md:p-10">
          <p class="mb-6 text-[0.78rem] font-semibold uppercase tracking-[0.24em] text-[#8ec8ff]">
            {content.officeEyebrow}
          </p>

          <h2 class="max-w-xl text-[clamp(2rem,4vw,3.6rem)] font-medium leading-[0.98] tracking-[-0.045em]">
            {content.officesTitle}
          </h2>

          <div class="mt-10 h-px w-full bg-white/12"></div>

          <div class="mt-10">
            <p class="text-sm font-medium uppercase tracking-[0.22em] text-white/45">
              {office.city}
            </p>

            <p class="mt-5 max-w-md text-[1.05rem] leading-8 text-white/72">
              {office.address}
            </p>
          </div>
        </div>

        <div class="rounded-[2rem] border border-[#0B2C4A]/10 bg-white p-8 shadow-[0_24px_80px_rgba(11,44,74,0.08)] md:p-10">
          <div class="grid gap-5 md:grid-cols-2">
            <div class="rounded-[1.25rem] bg-[#eef4fb] p-6">
              <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[#00B2EB]">
                {office.phoneLabel}
              </p>

              <a href={telHref} class="text-[1.15rem] font-medium text-[#0B2C4A] transition hover:text-[#00B2EB]">
                {office.phone}
              </a>
            </div>

            <div class="rounded-[1.25rem] bg-[#eef4fb] p-6">
              <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[#00B2EB]">
                {office.emailLabel}
              </p>

              <a href={`mailto:${office.email}`} class="break-all text-[1.15rem] font-medium text-[#0B2C4A] transition hover:text-[#00B2EB]">
                {office.email}
              </a>
            </div>
          </div>

          <div class="mt-5 rounded-[1.25rem] bg-[#eef4fb] p-6">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-[#00B2EB]">
              {office.addressName}
            </p>

            <p class="max-w-xl leading-7 text-[#0B2C4A]/70">
              {office.address}
            </p>
          </div>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href={`mailto:${office.email}`}
              class="inline-flex items-center justify-center rounded-full bg-[#0B2C4A] px-6 py-3 text-sm font-medium text-white transition hover:bg-[#00B2EB] hover:text-[#0B2C4A]"
            >
              {office.emailCta}
            </a>

            <a
              href={telHref}
              class="inline-flex items-center justify-center rounded-full border border-[#0B2C4A]/15 px-6 py-3 text-sm font-medium text-[#0B2C4A] transition hover:border-[#0B2C4A] hover:bg-white"
            >
              {office.phoneCta}
            </a>

            <a
              href={office.mapsHref}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center rounded-full border border-[#0B2C4A]/15 px-6 py-3 text-sm font-medium text-[#0B2C4A] transition hover:border-[#0B2C4A] hover:bg-white"
            >
              {office.mapsLabel}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 pb-24 md:px-6 md:pb-28">
      <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] border border-[#0B2C4A]/10 bg-white shadow-[0_24px_80px_rgba(11,44,74,0.08)]">
        <iframe
          title={`Map ${office.city}`}
          src={mapSrc}
          class="h-[420px] w-full border-0 md:h-[500px]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </section>
  </main>
</BaseLayout>