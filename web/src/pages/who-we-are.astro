---
import BaseLayout from "../layouts/Layout.astro";
import { whoWeArePageContent, type Locale } from "../lib/siteContent";
import { Image } from "astro:assets";

import analysisImage from "../assets/analysis-hero.png";

const locale: Locale = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const content = whoWeArePageContent[locale];
const contactHref = locale === "en" ? "/en/contact" : "/contact";

const addValueItems = [
  content.addValue.digitaltransformation,
  content.addValue.aiImplementation,
  content.addValue.dataStrategy,
];

const statsItems = [
  content.stats.focus,
  content.stats.approach,
  content.stats.expertise,
  content.stats.independence,
];

const journeySteps = [
  content.journey.steps.understand,
  content.journey.steps.identify,
  content.journey.steps.design,
  content.journey.steps.implement,
];

const peopleMindsetItems = [
  content.people.mindset.strategy,
  content.people.mindset.technology,
  content.people.mindset.automation,
  content.people.mindset.partnership,
];

const heroImages = {
  analysis: analysisImage,
} as const;

type HeroImageKey = keyof typeof heroImages;

---

<BaseLayout title={content.title} description={content.description}>

  <section class="bg-[#eef4fb] px-4 pb-20 pt-32 md:px-6 md:pb-28 md:pt-40">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
        <div>
          <p class="mb-6 text-[0.875rem] font-semibold uppercase tracking-[0.25em] text-[#00B2EB]">
            {content.hero.eyebrow}
          </p>

          <h1 class="max-w-4xl text-[clamp(2.3rem,4.6vw,4.4rem)] font-semibold leading-[0.92] tracking-[-0.06em] text-[#0B2C4A]">
            {content.hero.title}
          </h1>

          <a
            href={contactHref}
            class="mt-8 inline-flex items-center gap-3 rounded-full bg-[#0B2C4A] px-6 py-3.5 text-sm font-medium text-white transition hover:bg-[#00B2EB] hover:text-[#0B2C4A]"
          >
            {content.people.cta}
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="max-w-xl lg:justify-self-end">
          <div class="rounded-[2rem] border border-[#0B2C4A]/10 bg-white/70 p-8 shadow-[0_24px_70px_rgba(11,44,74,0.08)] backdrop-blur">
            <div class="mb-6 h-px w-16 bg-[#00B2EB]"></div>

            <div class="space-y-5 text-[1.05rem] leading-8 text-[#0B2C4A]/75 md:text-[1.12rem]">
              {content.hero.body.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
        </div>
      </div>

      <div class="mt-16 grid gap-5 lg:grid-cols-[1fr_0.42fr]">
        <div class="overflow-hidden rounded-[2rem] bg-[#0B2C4A] shadow-[0_28px_90px_rgba(11,44,74,0.18)]">
          <Image
            src={heroImages[content.hero.imageKey as HeroImageKey]}
            alt={content.hero.imageAlt}
            class="h-[420px] w-full object-cover md:h-[620px]"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {statsItems.map((item) => (
            <article class="rounded-[1.75rem] bg-[#0B2C4A] p-8 text-white">
              <p class="text-[clamp(2.4rem,4vw,4rem)] font-semibold leading-none tracking-[-0.06em]">
                {item.number}
              </p>
              <p class="mt-4 text-sm leading-6 text-white/75">
                {item.label}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 border-t border-[#0B2C4A]/12 pt-10 lg:grid-cols-[0.82fr_1.18fr]">
        <div>
          <p class="mb-6 text-[0.875rem] font-semibold uppercase tracking-[0.25em] text-[#00B2EB]">
            {content.difference.eyebrow}
          </p>
          <h2 class="max-w-2xl text-[clamp(2rem,4vw,3.6rem)] font-medium leading-[1] tracking-[-0.04em] text-[#0B2C4A]">
            {content.difference.title}
          </h2>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {content.difference.items.map((item, index) => (
            <article class="rounded-[1.5rem] border border-[#0B2C4A]/10 bg-white p-8 shadow-[0_18px_50px_rgba(11,44,74,0.06)] transition duration-500 hover:-translate-y-1 hover:shadow-[0_28px_70px_rgba(11,44,74,0.12)]">
              <p class="mb-10 text-xs font-semibold uppercase tracking-[0.25em] text-[#00B2EB]">
                {String(index + 1).padStart(2, "0")}
              </p>
              <h3 class="text-[1.25rem] font-medium tracking-[-0.04em] text-[#0B2C4A]">
                {item.title}
              </h3>
              <p class="mt-5 text-[1rem] leading-7 text-[#0B2C4A]/68">
                {item.text}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section data-nav-theme="light" class="bg-[#0B2C4A] px-4 py-20 text-white md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="mb-6 text-[0.875rem] font-semibold uppercase tracking-[0.25em] text-[#8ec8ff]">
            {content.values.eyebrow}
          </p>
          <h2 class="max-w-xl text-[clamp(2rem,4vw,3.6rem)] font-medium leading-[1] tracking-[-0.04em]">
            {content.values.title}
          </h2>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {content.values.items.map((item, index) => (
            <article class="min-h-[280px] rounded-[1.5rem] border border-white/10 bg-white/6 p-7 transition duration-500 hover:-translate-y-1 hover:border-white/30 hover:bg-white/10">
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-white/8 text-sm font-semibold text-[#8ec8ff]">
                {String(index + 1).padStart(2, "0")}
              </span>

              <h3 class="mt-10 text-[1.15rem] font-medium tracking-[-0.03em]">
                {item.title}
              </h3>

              <p class="mt-5 text-sm leading-6 text-white/75">
                {item.text}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#eef4fb] px-4 py-20 md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 border-t border-[#0B2C4A]/12 pt-10 lg:grid-cols-[0.85fr_1.15fr]">
        <div>
          {/* FIX: tracking unificado */}
          <p class="mb-6 text-[0.875rem] font-semibold uppercase tracking-[0.25em] text-[#00B2EB]">
            {content.addValue.title}
          </p>
          <h2 class="max-w-2xl text-[clamp(2rem,4vw,3.6rem)] font-medium leading-[1] tracking-[-0.04em] text-[#0B2C4A]">
            {content.addValue.description}
          </h2>
        </div>

        <div class="grid gap-5 md:grid-cols-3">
          {addValueItems.map((item) => (
            <article class="rounded-[1.5rem] bg-white p-7 shadow-[0_18px_50px_rgba(11,44,74,0.06)]">
              <h3 class="text-[1.15rem] font-medium tracking-[-0.04em] text-[#0B2C4A]">
                {item.title}
              </h3>
              {/* FIX: opacidad unificada a /68 — era /65 */}
              <p class="mt-5 text-sm leading-6 text-[#0B2C4A]/68">
                {item.text}
              </p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="border-t border-[#0B2C4A]/12 pt-10">
        <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
          <div>
            <p class="mb-6 text-[0.875rem] font-semibold uppercase tracking-[0.25em] text-[#00B2EB]">
              {content.journey.eyebrow}
            </p>

            <h2 class="max-w-2xl text-[clamp(2rem,4vw,3.6rem)] font-medium leading-[1] tracking-[-0.04em] text-[#0B2C4A]">
              {content.journey.title}
            </h2>
          </div>

          <div class="relative grid gap-4 md:grid-cols-4">
            <div class="absolute left-0 top-9 hidden h-px w-full bg-[#0B2C4A]/12 lg:block"></div>

            {journeySteps.map((step) => (
              <article class="group relative rounded-[1.5rem] border border-[#0B2C4A]/10 bg-[#f6f9fc] p-6 transition duration-500 hover:-translate-y-1 hover:border-[#00B2EB]/35 hover:bg-white hover:shadow-[0_24px_70px_rgba(11,44,74,0.10)]">
                <div class="relative z-10 mb-6 inline-flex h-12 w-12 items-center justify-center rounded-full border border-[#0B2C4A]/10 bg-white text-sm font-semibold text-[#0B2C4A] shadow-[0_10px_30px_rgba(11,44,74,0.08)] transition group-hover:border-[#00B2EB]/40 group-hover:text-[#00B2EB]">
                  {step.number}
                </div>

                <p class="text-sm leading-6 text-[#0B2C4A]/68">
                  {step.text}
                </p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#eef4fb] px-4 py-20 md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="border-t border-[#0B2C4A]/12 pt-10">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
          <div>
            <p class="mb-6 text-[0.875rem] font-semibold uppercase tracking-[0.25em] text-[#00B2EB]">
              {content.people.eyebrow}
            </p>

            <h2 class="max-w-2xl text-[clamp(2rem,4vw,3.6rem)] font-medium leading-[1] tracking-[-0.04em] text-[#0B2C4A]">
              {content.people.title}
            </h2>
          </div>

          <div class="max-w-2xl lg:justify-self-end">
            <p class="text-[1.08rem] leading-8 text-[#0B2C4A]/68">
              {content.people.text}
            </p>

            <a
              href={contactHref}
              class="mt-8 inline-flex items-center gap-3 rounded-full bg-[#0B2C4A] px-6 py-3.5 text-sm font-medium text-white transition hover:bg-[#00B2EB] hover:text-[#0B2C4A]"
            >
              {content.people.cta}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="mt-16 grid gap-4 md:grid-cols-4">
          {peopleMindsetItems.map((item) => (
            <article class="group relative min-h-[300px] overflow-hidden rounded-[1.5rem] border border-[#0B2C4A]/10 bg-white p-7 shadow-[0_18px_50px_rgba(11,44,74,0.06)] transition duration-500 hover:-translate-y-2 hover:border-[#00B2EB]/30 hover:shadow-[0_28px_80px_rgba(11,44,74,0.12)]">
              <div class="absolute inset-x-0 top-0 h-1 bg-[#00B2EB] opacity-0 transition duration-500 group-hover:opacity-100"></div>

              <div class="flex items-center gap-3">
                <span class="h-2.5 w-2.5 rounded-full bg-[#00B2EB]"></span>
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[#00B2EB]">
                  {content.people.mindsetEyebrow}
                </p>
              </div>

              <div class="mt-16">
                <h3 class="text-[1.35rem] font-medium leading-[1.05] tracking-[-0.04em] text-[#0B2C4A]">
                  {item.title}
                </h3>

                <p class="mt-6 text-sm leading-6 text-[#0B2C4A]/68">
                  {item.text}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section data-nav-theme="light" class="bg-white px-4 py-20 md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <a
        href={contactHref}
        class="group block overflow-hidden rounded-[2rem] bg-[#0B2C4A] p-8 text-white shadow-[0_28px_90px_rgba(11,44,74,0.22)] transition-all duration-700 hover:rounded-[2.5rem] md:p-14"
      >
        <div class="flex flex-col gap-10 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="mb-5 text-xs font-semibold uppercase tracking-[0.25em] text-white/55">
              {content.finalCta.eyebrow}
            </p>

            <h2 class="max-w-4xl text-[clamp(2.2rem,5vw,4.2rem)] font-medium leading-[0.98] tracking-[-0.045em]">
              {content.finalCta.title}
            </h2>

            <div class="grid max-h-0 overflow-hidden opacity-0 transition-all duration-700 ease-out group-hover:mt-4 group-hover:max-h-64 group-hover:opacity-100">
              <h3 class="max-w-4xl text-[clamp(2.2rem,5vw,4.2rem)] font-medium leading-[0.98] tracking-[-0.045em] text-[#00B2EB]">
                {content.finalCta.highlight}
              </h3>

              <p class="mt-8 max-w-2xl text-[1.05rem] leading-7 text-white/75 md:text-[1.15rem]">
                {content.finalCta.text}
              </p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <span class="hidden text-sm font-medium text-white/55 transition-opacity duration-500 group-hover:opacity-100 md:block">
              {content.finalCta.linkLabel}
            </span>

            <span class="grid h-16 w-16 place-items-center rounded-full bg-white text-3xl text-[#0B2C4A] transition duration-500 group-hover:scale-110">
              →
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>