---
import { Image, getImage } from "astro:assets";

import analyticsImage from "../assets/analysis.jpg";
import machineLearningImage from "../assets/machine-learning.jpg";
import deepLearningImage from "../assets/deep-learning.jpg";
import BaseLayout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProcessTimeline from "../components/ProcessTimeline.astro";
import { homeContent, type Locale } from "../lib/siteContent";

const locale: Locale = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const content = homeContent[locale];
const areaImages = {
  analysis: analyticsImage,
  machineLearning: machineLearningImage,
  deepLearning: deepLearningImage,
} as const;

type AreaImageKey = keyof typeof areaImages;

const focusAreas = await Promise.all(
  content.whatWeDo.areas.map(async (area) => {
    const imageKey = area.imageKey as AreaImageKey;
    const imageAsset = areaImages[imageKey];

    const optimizedImage = await getImage({
      src: imageAsset,
      width: 520,
      height: 680,
      format: "webp",
      quality: 72,
    });

    return {
      ...area,
      imageAsset,
      imageSrc: optimizedImage.src,
    };
  })
);
---

<BaseLayout title={content.title} description={content.description}>
  <Hero locale={locale} />

  <section id="what-we-do" class="bg-[#eef4fb] px-4 py-20 md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 border-t border-[#071729]/12 pt-8 md:grid-cols-[0.82fr_1.18fr] md:pt-12">
        <div>
          <p class="mb-6 text-[0.78rem] font-semibold uppercase tracking-[0.22em] text-[#0d3c78]">
            {content.whatWeDo.eyebrow}
          </p>
          <h2 class="max-w-2xl text-[clamp(2rem,3.8vw,3.6rem)] font-medium leading-[0.96] tracking-[-0.05em] text-[#071729]">
            {content.whatWeDo.title}
          </h2>
          <p class="mt-5 max-w-xl text-[1rem] leading-7 text-[#071729]/68 md:text-[1.05rem]">
            {content.whatWeDo.description}
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {focusAreas.map((area) => (
            <a
              href={locale === "en" ? "/en/services" : "/services"}
              aria-label={`Saber más sobre el servicio de ${area.title}`}
              class="group relative block min-h-[380px] overflow-hidden rounded-[1.25rem] bg-[#071729] shadow-[0_20px_50px_rgba(7,23,41,0.12)]"
            >
              <Image
				src={area.imageAsset}
				alt={`Imagen representativa de ${area.title}`}
				width={520}
				height={680}
				format="webp"
				quality={72}
				class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
				loading="lazy"
				decoding="async"
			  />
              <div class="absolute inset-0 bg-gradient-to-t from-[#071729]/78 via-[#071729]/10 to-transparent"></div>
              <div class="absolute inset-0 flex flex-col justify-between p-6">
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/55">
                  {area.eyebrow}
                </p>
                <div class="flex items-end justify-between gap-3">
                  <div class="max-w-[14rem]">
                    <h3 class="text-[1.15rem] font-medium tracking-[-0.03em] text-white">
                      {area.title}
                    </h3>
                    <p class="mt-2 text-sm leading-6 text-white/72">
                      {area.description}
                    </p>
                  </div>
                  <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-white text-sm font-medium leading-none text-[#071729] transition duration-500 group-hover:scale-105 group-hover:scale-105 md:h-10 md:w-10 md:text-base">
					→
				  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ProcessTimeline locale={locale} />

  <section
    id="who-we-are"
    data-nav-theme="light"
    class="bg-[#0B2C4A] px-4 py-20 text-white md:px-6 md:py-28"
  >
    <div class="mx-auto grid max-w-7xl gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-start">
      <div>
        <p class="mb-5 text-[0.78rem] font-semibold uppercase tracking-[0.22em] text-[#8ec8ff]">
          {content.whoWeAre.eyebrow}
        </p>
        <h2 class="text-[clamp(2.1rem,4.5vw,4rem)] font-medium leading-[0.92] tracking-[-0.055em]">
          {content.whoWeAre.title}
        </h2>
        <div class="mt-6 h-px w-20 bg-white/20"></div>
      </div>

      <div class="max-w-2xl space-y-5 text-[1.05rem] leading-8 text-white/72 md:text-[1.12rem]">
        {content.whoWeAre.body.map((paragraph) => <p>{paragraph}</p>)}

        <div class="grid gap-4 pt-3 sm:grid-cols-3">
          {content.whoWeAre.pillars.map((pillar) => (
            <div class="rounded-[1.1rem] border border-white/10 bg-white/5 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/45">
                {pillar.title}
              </p>
              <p class="mt-2 text-sm leading-6 text-white/80">{pillar.text}</p>
            </div>
          ))}
        </div>

        <a
          href={locale === "en" ? "/en/who-we-are" : "/who-we-are"}
          class="inline-flex rounded-full bg-white px-6 py-3 text-sm font-medium text-[#071729] transition hover:bg-[#dcecff]"
        >
          {content.whoWeAre.ctaLabel}
        </a>
      </div>
    </div>
  </section>

  <section id="contact" data-nav-theme="light" class="bg-[#eef4fb] px-4 py-20 md:px-6 md:py-28">
    <div class="mx-auto max-w-7xl">
      <a
        href="/contact"
        class="group block overflow-hidden rounded-[2rem] bg-[#0B2C4A] p-8 text-white shadow-[0_28px_90px_rgba(11,44,74,0.22)] transition-all duration-700 hover:rounded-[2.5rem] md:p-14"
      >
        <div class="flex flex-col gap-10 md:flex-row md:items-end md:justify-between">
		<div>
			<p class="mb-5 text-xs font-semibold uppercase tracking-[0.26em] text-white/55">
			{content.contact.eyebrow}
			</p>

			<h2 class="max-w-4xl text-[clamp(2.2rem,5vw,4.2rem)] font-medium leading-[0.98] tracking-[-0.045em]">
			{content.contact.title}
			</h2>

			<div class="grid mt-4 max-h-64 overflow-hidden opacity-100 transition-all duration-700 ease-out md:mt-0 md:max-h-0 md:opacity-0 md:group-hover:mt-4 md:group-hover:max-h-64 md:group-hover:opacity-100">
			<h3 class="max-w-4xl text-[clamp(2.2rem,5vw,4.2rem)] font-medium leading-[0.98] tracking-[-0.045em] text-[#00B2EB]">
				{content.contact.highlight}
			</h3>

			<p class="mt-8 max-w-2xl text-[1.05rem] leading-7 text-white/70 md:text-[1.15rem]">
				{content.contact.description}
			</p>
			</div>
		</div>

		<div class="flex items-center gap-4">
			<span class="hidden text-sm font-medium text-white/60 transition-opacity duration-500 group-hover:opacity-100 md:block">
			{content.contact.contactLabel}
			</span>

			<span class="grid h-16 w-16 place-items-center rounded-full bg-white text-3xl text-[#0B2C4A] transition duration-500 group-hover:scale-110 group-hover:scale-110">
			→
			</span>
		</div>
		</div>
      </a>
    </div>
  </section>
</BaseLayout>
