---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { blogPageContent, type Locale } from '../../../lib/siteContent';
import BlogCard from '../../../components/BlogCard.astro';

const locale: Locale = 'en';
const t = blogPageContent[locale];

const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === locale;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title={t.title} description={t.description}>
  <section class="relative min-h-screen bg-mist px-4 pb-20 pt-32 md:px-6">
    <div class="mx-auto max-w-7xl">
      <header class="mb-16">
        <span class="mb-4 block text-xs font-bold uppercase tracking-[0.2em] text-blue">
          {t.eyebrow}
        </span>

        <h1 class="max-w-3xl text-4xl font-bold text-ink md:text-5xl">
          {t.title}
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-ink/65">
          {t.description}
        </p>
      </header>

      {sortedPosts.length > 0 ? (
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {sortedPosts.map((post) => (
            <BlogCard post={post} locale={locale} />
          ))}
        </div>
      ) : (
        <div class="rounded-3xl border-2 border-dashed border-black/10 py-20 text-center">
          <p class="font-medium text-black/50">{t.empty}</p>
        </div>
      )}
    </div>
  </section>
</Layout>